{
  "name": "air-strafer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot --port 5174 src/index.html",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "preview": "bun --port 4174 dist/index.html"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
